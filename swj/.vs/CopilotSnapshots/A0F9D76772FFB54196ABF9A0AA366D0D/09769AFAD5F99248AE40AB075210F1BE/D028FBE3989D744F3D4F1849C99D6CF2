using System;
using System.Windows.Forms;
using Microsoft.Data.SqlClient;

namespace WinFormsApp1
{
    public partial class Form1 : Form
    {
        private readonly string connStr = @"Data Source=xiaoxi;Initial Catalog=MyDatabase1;Integrated Security=True;TrustServerCertificate=True;";

        public Form1()
        {
            InitializeComponent();
        }

        private void Form1_Load(object sender, EventArgs e)
        {
            txtPassword.UseSystemPasswordChar = true;
        }

        private void textBox1_TextChanged(object sender, EventArgs e)
        {

        }

        private void btnLogin_Click(object sender, EventArgs e)
        {
            string userName = txtUserName.Text.Trim();
            string password = txtPassword.Text.Trim();

            if (string.IsNullOrEmpty(userName) || string.IsNullOrEmpty(password))
            {
                MessageBox.Show("请输入用户名和密码！");
                return;
            }

            try
            {
                using (SqlConnection conn = new SqlConnection(connStr))
                {
                    conn.Open();

                    string sql = @"SELECT COUNT(*)
                                   FROM AdminUser
                                   WHERE UserName = @UserName
                                     AND PasswordHash = @Password
                                     AND IsEnabled = 1";

                    using (SqlCommand cmd = new SqlCommand(sql, conn))
                    {
                        cmd.Parameters.AddWithValue("@UserName", userName);
                        cmd.Parameters.AddWithValue("@Password", password);

                        int count = Convert.ToInt32(cmd.ExecuteScalar());

                        if (count > 0)
                        {
                            string logSql = @"INSERT INTO OperationLog (AdminID, OperationType, OperationContent, OperationIP)
                                              SELECT AdminID, @OperationType, @OperationContent, @OperationIP
                                              FROM AdminUser
                                              WHERE UserName = @UserName";

                            using (SqlCommand logCmd = new SqlCommand(logSql, conn))
                            {
                                logCmd.Parameters.AddWithValue("@OperationType", "登录");
                                logCmd.Parameters.AddWithValue("@OperationContent", "管理员登录系统");
                                logCmd.Parameters.AddWithValue("@OperationIP", "127.0.0.1");
                                logCmd.Parameters.AddWithValue("@UserName", userName);
                                logCmd.ExecuteNonQuery();
                            }

                            MessageBox.Show("登录成功！");

                            MainForm mainForm = new MainForm();
                            mainForm.Show();
                            this.Hide();
                        }
                        else
                        {
                            MessageBox.Show("用户名或密码错误！");
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("数据库连接或查询失败：\n" + ex.Message);
            }
        }
    }
}