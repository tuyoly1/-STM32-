using System;
using System.Drawing.Drawing2D;
using System.Windows.Forms;
using Microsoft.Data.SqlClient;

namespace WinFormsApp1
{
    public partial class Form1 : Form
    {
        private readonly string connStr = @"Data Source=xiaoxi;Initial Catalog=MyDatabase1;Integrated Security=True;TrustServerCertificate=True;";
        private System.Windows.Forms.Timer animationTimer;
        private float gradientAngle = 0f;

        public Form1()
        {
            InitializeComponent();
            this.DoubleBuffered = true;
        }

        private void Form1_Load(object sender, EventArgs e)
        {
            // 禁用默认的窗体背景处理
            this.BackColor = Color.White;
            UIHelper.StyleForm(this);
            StyleLoginForm();
            
            txtPassword.UseSystemPasswordChar = true;
            
            // 启动渐变背景动画
            StartGradientAnimation();
        }

        private void StartGradientAnimation()
        {
            animationTimer = new System.Windows.Forms.Timer();
            animationTimer.Interval = 50; // 50ms 更新一次
            animationTimer.Tick += (s, e) =>
            {
                gradientAngle += 0.5f;
                if (gradientAngle >= 360f)
                    gradientAngle = 0f;
                pnlLeft.Invalidate(); // 重绘左侧面板
            };
            animationTimer.Start();
            
            // 自定义绘制左侧面板背景
            pnlLeft.Paint += PnlLeft_Paint;
        }

        private void PnlLeft_Paint(object sender, PaintEventArgs e)
        {
            // 创建动态渐变背景
            Rectangle rect = pnlLeft.ClientRectangle;
            
            // 使用旋转的渐变
            using (LinearGradientBrush brush = new LinearGradientBrush(
                rect,
                UIHelper.Colors.Primary,           // 主蓝色
                Color.FromArgb(52, 152, 219),      // 稍深的蓝色
                gradientAngle))
            {
                // 添加渐变颜色点，营造更炫彩的效果
                ColorBlend blend = new ColorBlend(3);
                blend.Colors = new[]
                {
                    UIHelper.Colors.Primary,                    // 蓝色
                    Color.FromArgb(41, 128, 185),              // 深蓝
                    UIHelper.Colors.Primary                     // 回到蓝色
                };
                blend.Positions = new[] { 0f, 0.5f, 1f };
                brush.InterpolationColors = blend;
                
                e.Graphics.FillRectangle(brush, rect);
            }
            
            // 绘制半透明的装饰圆形（可选）
            DrawDecorationCircles(e.Graphics, rect);
        }

        private void DrawDecorationCircles(Graphics g, Rectangle rect)
        {
            // 添加几个半透明的圆形装饰，增加视觉效果
            g.SmoothingMode = SmoothingMode.AntiAlias;
            
            int radius1 = (int)(80 + Math.Sin(gradientAngle * Math.PI / 180) * 20);
            int radius2 = (int)(100 + Math.Cos(gradientAngle * Math.PI / 180) * 20);
            int radius3 = (int)(60 + Math.Sin((gradientAngle + 120) * Math.PI / 180) * 20);
            
            using (Brush brush1 = new SolidBrush(Color.FromArgb(20, 255, 255, 255)))
            {
                g.FillEllipse(brush1, rect.Width - radius1 - 30, -20, radius1 * 2, radius1 * 2);
            }
            
            using (Brush brush2 = new SolidBrush(Color.FromArgb(15, 0, 0, 0)))
            {
                g.FillEllipse(brush2, -40, rect.Height - radius2, radius2 * 2, radius2 * 2);
            }
            
            using (Brush brush3 = new SolidBrush(Color.FromArgb(25, 255, 255, 255)))
            {
                g.FillEllipse(brush3, rect.Width - radius3, rect.Height / 2 - radius3, radius3 * 2, radius3 * 2);
            }
        }

        private void StyleLoginForm()
        {
            // 左侧蓝色面板样式
            pnlLeft.BackColor = UIHelper.Colors.Primary;
            
            // 右侧卡片样式
            pnlCard.BackColor = Color.White;
            
            // 文本框样式
            StyleTextBoxes();
            
            // 按钮样式
            StyleButtons();
        }

        private void StyleTextBoxes()
        {
            // 用户名输入框
            txtUserName.BorderStyle = BorderStyle.None;
            txtUserName.BackColor = Color.White;
            txtUserName.Font = new Font("微软雅黑", 11);
            txtUserName.ForeColor = UIHelper.Colors.DarkText;
            
            // 密码输入框
            txtPassword.BorderStyle = BorderStyle.None;
            txtPassword.BackColor = Color.White;
            txtPassword.Font = new Font("微软雅黑", 11);
            txtPassword.ForeColor = UIHelper.Colors.DarkText;
            txtPassword.UseSystemPasswordChar = true;
        }

        private void StyleButtons()
        {
            // 登录按钮 - 蓝色主按钮
            btnLogin.FlatStyle = FlatStyle.Flat;
            btnLogin.FlatAppearance.BorderSize = 0;
            btnLogin.BackColor = UIHelper.Colors.Primary;
            btnLogin.ForeColor = UIHelper.Colors.LightText;
            btnLogin.Font = new Font("微软雅黑", 13, FontStyle.Bold);
            btnLogin.Cursor = Cursors.Hand;
            btnLogin.Height = 48;
            
            // 登录按钮悬停效果
            btnLogin.MouseEnter += (s, e) =>
            {
                btnLogin.BackColor = AdjustBrightness(UIHelper.Colors.Primary, 1.15);
            };
            btnLogin.MouseLeave += (s, e) =>
            {
                btnLogin.BackColor = UIHelper.Colors.Primary;
            };
            btnLogin.MouseDown += (s, e) =>
            {
                btnLogin.BackColor = AdjustBrightness(UIHelper.Colors.Primary, 0.85);
            };
            btnLogin.MouseUp += (s, e) =>
            {
                btnLogin.BackColor = AdjustBrightness(UIHelper.Colors.Primary, 1.15);
            };

            // 退出按钮 - 灰色副按钮
            btnCancel.FlatStyle = FlatStyle.Flat;
            btnCancel.FlatAppearance.BorderSize = 0;
            btnCancel.BackColor = UIHelper.Colors.Info;
            btnCancel.ForeColor = UIHelper.Colors.LightText;
            btnCancel.Font = new Font("微软雅黑", 11, FontStyle.Bold);
            btnCancel.Cursor = Cursors.Hand;
            btnCancel.Height = 40;
            
            // 退出按钮悬停效果
            btnCancel.MouseEnter += (s, e) =>
            {
                btnCancel.BackColor = AdjustBrightness(UIHelper.Colors.Info, 1.15);
            };
            btnCancel.MouseLeave += (s, e) =>
            {
                btnCancel.BackColor = UIHelper.Colors.Info;
            };
            btnCancel.MouseDown += (s, e) =>
            {
                btnCancel.BackColor = AdjustBrightness(UIHelper.Colors.Info, 0.85);
            };
            btnCancel.MouseUp += (s, e) =>
            {
                btnCancel.BackColor = AdjustBrightness(UIHelper.Colors.Info, 1.15);
            };
        }

        private Color AdjustBrightness(Color color, double factor)
        {
            return Color.FromArgb(
                (int)(color.R * factor > 255 ? 255 : color.R * factor),
                (int)(color.G * factor > 255 ? 255 : color.G * factor),
                (int)(color.B * factor > 255 ? 255 : color.B * factor));
        }

