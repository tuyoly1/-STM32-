        private readonly string connStr = @"Data Source=xiaoxi;Initial Catalog=MyDatabase1;Integrated Security=True;TrustServerCertificate=True;";

        public Form1()
        {
            InitializeComponent();
            this.DoubleBuffered = true;
        }

        private void Form1_Load(object sender, EventArgs e)
        {
            // 禁用默认的窗体背景处理
            this.BackColor = Color.White;
            UIHelper.StyleForm(this);
            StyleLoginForm();
            
            txtPassword.UseSystemPasswordChar = true;
            
            // 设置左侧面板的背景图片
            SetPanelBackground();
        }

        private void SetPanelBackground()
        {
            string imagePath = "tsg.png";
            
            try
            {
                if (System.IO.File.Exists(imagePath))
                {
                    pnlLeft.BackgroundImage = Image.FromFile(imagePath);
                    pnlLeft.BackgroundImageLayout = ImageLayout.Stretch;
                    System.Diagnostics.Debug.WriteLine($"✓ 成功加载背景图片: {imagePath}");
                }
                else
                {
                    System.Diagnostics.Debug.WriteLine($"✗ 找不到图片文件: {imagePath}");
                    
                    // 尝试其他可能的路径
                    string[] possiblePaths = new[]
                    {
                        "tsg.png",
                        System.IO.Path.Combine("bin", "Debug", "net8.0-windows", "tsg.png"),
                        System.IO.Path.Combine("..", "bin", "Debug", "net8.0-windows", "tsg.png"),
                        System.IO.Path.Combine("Resources", "tsg.png"),
                    };
                    
                    bool found = false;
                    foreach (var path in possiblePaths)
                    {
                        if (System.IO.File.Exists(path))
                        {
                            System.Diagnostics.Debug.WriteLine($"✓ 在以下位置找到图片: {path}");
                            pnlLeft.BackgroundImage = Image.FromFile(path);
                            pnlLeft.BackgroundImageLayout = ImageLayout.Stretch;
                            found = true;
                            break;
                        }
                    }
                    
                    if (!found)
                    {
                        System.Diagnostics.Debug.WriteLine($"✗ 无法在任何路径找到图片，使用默认蓝色背景");
                        pnlLeft.BackColor = UIHelper.Colors.Primary;
                    }
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"✗ 加载背景图片出错: {ex.Message}");
                pnlLeft.BackColor = UIHelper.Colors.Primary;
            }
        }

        private void StyleLoginForm()
        {
            // 左侧面板样式（已在 SetPanelBackground 中设置背景）
            // pnlLeft.BackColor 已在 SetPanelBackground 中设置
            
            // 右侧卡片样式
            pnlCard.BackColor = Color.White;
            
            // 文本框样式
            StyleTextBoxes();
            
            // 按钮样式
