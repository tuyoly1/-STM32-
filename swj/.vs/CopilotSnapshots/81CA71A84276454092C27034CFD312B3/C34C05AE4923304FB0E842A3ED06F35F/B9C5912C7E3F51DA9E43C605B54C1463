        private void StyleTextBoxes()
        {
            // 用户名输入框
            txtUserName.BorderStyle = BorderStyle.None;
            txtUserName.BackColor = Color.White;
            txtUserName.Font = new Font("微软雅黑", 11);
            txtUserName.ForeColor = UIHelper.Colors.DarkText;
            
            // 密码输入框
            txtPassword.BorderStyle = BorderStyle.None;
            txtPassword.BackColor = Color.White;
            txtPassword.Font = new Font("微软雅黑", 11);
            txtPassword.ForeColor = UIHelper.Colors.DarkText;
            txtPassword.UseSystemPasswordChar = true;
        }

        private void StyleButtons()
        {
            // 登录按钮 - 蓝色主按钮
            btnLogin.FlatStyle = FlatStyle.Flat;
            btnLogin.FlatAppearance.BorderSize = 0;
            btnLogin.BackColor = UIHelper.Colors.Primary;
            btnLogin.ForeColor = UIHelper.Colors.LightText;
            btnLogin.Font = new Font("微软雅黑", 13, FontStyle.Bold);
            btnLogin.Cursor = Cursors.Hand;
            btnLogin.Height = 48;
            
            // 登录按钮悬停效果
            btnLogin.MouseEnter += (s, e) =>
            {
                btnLogin.BackColor = AdjustBrightness(UIHelper.Colors.Primary, 1.15);
            };
            btnLogin.MouseLeave += (s, e) =>
            {
                btnLogin.BackColor = UIHelper.Colors.Primary;
            };
            btnLogin.MouseDown += (s, e) =>
            {
                btnLogin.BackColor = AdjustBrightness(UIHelper.Colors.Primary, 0.85);
            };
            btnLogin.MouseUp += (s, e) =>
            {
                btnLogin.BackColor = AdjustBrightness(UIHelper.Colors.Primary, 1.15);
            };

            // 退出按钮 - 灰色副按钮
            btnCancel.FlatStyle = FlatStyle.Flat;
            btnCancel.FlatAppearance.BorderSize = 0;
            btnCancel.BackColor = UIHelper.Colors.Info;
            btnCancel.ForeColor = UIHelper.Colors.LightText;
            btnCancel.Font = new Font("微软雅黑", 11, FontStyle.Bold);
            btnCancel.Cursor = Cursors.Hand;
            btnCancel.Height = 40;
            
            // 退出按钮悬停效果
            btnCancel.MouseEnter += (s, e) =>
            {
                btnCancel.BackColor = AdjustBrightness(UIHelper.Colors.Info, 1.15);
            };
            btnCancel.MouseLeave += (s, e) =>
            {
                btnCancel.BackColor = UIHelper.Colors.Info;
            };
            btnCancel.MouseDown += (s, e) =>
            {
                btnCancel.BackColor = AdjustBrightness(UIHelper.Colors.Info, 0.85);
            };
            btnCancel.MouseUp += (s, e) =>
            {
                btnCancel.BackColor = AdjustBrightness(UIHelper.Colors.Info, 1.15);
            };
        }

        private Color AdjustBrightness(Color color, double factor)
        {
            return Color.FromArgb(
                (int)(color.R * factor > 255 ? 255 : color.R * factor),
                (int)(color.G * factor > 255 ? 255 : color.G * factor),
                (int)(color.B * factor > 255 ? 255 : color.B * factor));
        }

